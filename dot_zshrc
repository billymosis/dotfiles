# source $HOME/.cargo/env 2>/dev/null

# Lazy-load NVM. Shell starts ~750ms faster; first node/npm/npx/nvm call pays
# the one-time load cost. Shim functions are unset on first invocation.
if [[ "$(uname)" == "Darwin" ]]; then
	export HOMEBREW_NVM_DIR="/opt/homebrew/opt/nvm"
	_nvm_sh="$HOMEBREW_NVM_DIR/nvm.sh"
	_nvm_completion="$HOMEBREW_NVM_DIR/etc/bash_completion.d/nvm"
else
	_nvm_sh="$NVM_DIR/nvm.sh"
	_nvm_completion="$NVM_DIR/bash_completion"
fi

if [[ -s "$_nvm_sh" ]]; then
	# Each shim is self-contained: it loads nvm inline rather than calling a
	# separate helper. Some non-interactive/agent shells strip underscore-prefixed
	# "private" functions when restoring the env, which would leave the shim
	# calling a helper that no longer exists (command not found: _lazy_nvm).
	for _cmd in node npm npx nvm yarn pnpm corepack; do
		eval "$_cmd() {
			unset -f node npm npx nvm yarn pnpm corepack 2>/dev/null
			\. \"$_nvm_sh\"
			[[ -s \"$_nvm_completion\" ]] && \. \"$_nvm_completion\"
			$_cmd \"\$@\"
		}"
	done
	unset _cmd
fi

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

[[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path zsh)"

# THIS MUST BE AT THE END
export SDKMAN_DIR="$HOME/.sdkman"
# Lazy-load SDKMAN. sdkman-init.sh costs ~300-500ms per shell; keep the current
# candidate binaries (java/gradle/spring) on PATH directly and defer the full
# init (the `sdk` function, completions, auto-env) until first `sdk` invocation.
# Caveat: .sdkmanrc directory auto-env won't fire until you've run `sdk` once.
if [[ -d "$SDKMAN_DIR" ]]; then
	for _sdk_bin in "$SDKMAN_DIR"/candidates/*/current/bin(N); do
		export PATH="$PATH:${_sdk_bin}"
	done
	unset _sdk_bin
	# Lazy init never sets JAVA_HOME; jdtls/gradle/maven need it for project import.
	[[ -d "$SDKMAN_DIR/candidates/java/current" ]] && \
		export JAVA_HOME="$SDKMAN_DIR/candidates/java/current"
	sdk() {
		unset -f sdk
		source "$SDKMAN_DIR/bin/sdkman-init.sh"
		sdk "$@"
	}
fi

