# ==========================================
# 2. TMUX & WSL CONFIGURATION
# ==========================================
ZSH_THEME="billy"
local my_plugins=(git)

# Only run if not in VSCode
if [[ "$TERM_PROGRAM" != "vscode" ]]; then

	# A. If we are ALREADY inside Tmux (The Inner Shell)
	if [[ -n "$TMUX" ]]; then
		# Fix WSL Interop (The "Socket" Issue)
		if [[ -n "$WSL_INTEROP" && "$(uname)" == "Linux" ]]; then
			export WSL_INTEROP=/run/WSL/$(ls -tr /run/WSL/ | grep interop | tail -1)
		fi

		# Load heavy plugins only inside tmux
		my_plugins+=(zsh-autosuggestions kubectl common-aliases zsh-vi-mode)

	# B. If we are OUTSIDE Tmux (The Launcher)
	else
		session_name="BMP"

		# Ensure session exists
		tmux has-session -t=$session_name 2>/dev/null
		if [[ $? -ne 0 ]]; then
			TMUX='' tmux new-session -d -s "$session_name"
		fi

		# Attach. This will BLOCK here until you detach.
		# Because Exports are now above this line, Tmux inherits the correct PATH.
		tmux attach -t "$session_name"
	fi
fi

# ==========================================
# 3. OH-MY-ZSH & PLUGINS
# ==========================================
plugins=($my_plugins)

# Per-context completion dump: keeps a separate cache for tmux/vscode/plain shells
# so switching contexts doesn't nuke and rebuild the dump every time (~150ms saved).
[[ -d "${HOME}/.cache" ]] || mkdir -p "${HOME}/.cache"
export ZSH_COMPDUMP="${HOME}/.cache/zcompdump-${ZSH_VERSION}${TMUX:+-tmux}${TERM_PROGRAM:+-${TERM_PROGRAM}}"

