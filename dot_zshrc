# ==========================================
# 2. TMUX & WSL CONFIGURATION
# ==========================================
ZSH_THEME="billy"
local my_plugins=(git)

# Only run if not in VSCode or herdr
if [[ "$TERM_PROGRAM" != "vscode" && -z "$HERDR_ENV" ]]; then

	# A. If we are ALREADY inside Tmux (The Inner Shell)
	if [[ -n "$TMUX" ]]; then
		# Fix WSL Interop (The "Socket" Issue)
		if [[ -n "$WSL_INTEROP" && "$(uname)" == "Linux" ]]; then
			export WSL_INTEROP=/run/WSL/$(ls -tr /run/WSL/ | grep interop | tail -1)
		fi

		# Load heavy plugins only inside tmux
		my_plugins+=(zsh-autosuggestions kubectl common-aliases)

	# B. If we are OUTSIDE Tmux (The Launcher)
	else
		session_name="BMP"

		# Ensure session exists
		tmux has-session -t=$session_name 2>/dev/null
		if [[ $? -ne 0 ]]; then
			TMUX='' tmux new-session -d -s "$session_name"
		fi

		# Attach. This will BLOCK here until you detach.
		# Because Exports are now above this line, Tmux inherits the correct PATH.
		tmux attach -t "$session_name"
	fi
fi

# ==========================================
# 3. OH-MY-ZSH & PLUGINS
# ==========================================
plugins=($my_plugins)

# Per-context completion dump: keeps a separate cache for tmux/vscode/plain shells
# so switching contexts doesn't nuke and rebuild the dump every time (~150ms saved).
[[ -d "${HOME}/.cache" ]] || mkdir -p "${HOME}/.cache"
export ZSH_COMPDUMP="${HOME}/.cache/zcompdump-${ZSH_VERSION}${TMUX:+-tmux}${TERM_PROGRAM:+-${TERM_PROGRAM}}"

# ---- Defer the completion system off the startup critical path ----
# compinit (OMZ's completion init) is ~70% of shell startup (~250ms). Shadow the
# compinit that OMZ autoloads with a no-op that only buffers compdef calls, let
# OMZ load instantly, then run the real compinit + replay the buffered compdefs
# the moment the line editor first goes idle (prompt already on screen).
# Trade-off: tab-completion is unavailable for ~150ms after the prompt appears.
ZSH_DISABLE_COMPFIX=true
_fast_compdump="${HOME}/.cache/zcompdump-fast-${ZSH_VERSION}${TMUX:+-tmux}${TERM_PROGRAM:+-${TERM_PROGRAM}}"
_fast_shadow="${HOME}/.cache/zsh-fast-compinit"
if [[ ! -e "$_fast_shadow/compinit" ]]; then
	mkdir -p "$_fast_shadow"
	print -r -- 'typeset -ga _fast_compdefs
compdef() { _fast_compdefs+=("${(j: :)${(q)@}}") }' >| "$_fast_shadow/compinit"
fi
fpath=("$_fast_shadow" $fpath)   # autoload -U compinit now resolves to the no-op

source $ZSH/oh-my-zsh.sh

# Run the real completion init once, deferred to the first idle of the line editor.
_fast_init_completion() {
	(( ${_fast_done:-0} )) && return        # idempotent: only the first caller wins
	_fast_done=1
	emulate -L zsh
	fpath=(${fpath:#$_fast_shadow})
	unfunction compinit compdef 2>/dev/null
	autoload -Uz compinit
	local -a fresh=( "$_fast_compdump"(Nmh-20) )
	if (( $#fresh )); then
		compinit -C -d "$_fast_compdump"
	else
		compinit -d "$_fast_compdump"
	fi
	local c
	for c in $_fast_compdefs; do eval "compdef $c"; done
	unset _fast_compdefs
}
_fast_run_deferred() {
	[[ -n $_fast_fd ]] && { zle -F $_fast_fd; exec {_fast_fd}<&-; unset _fast_fd; }
	_fast_init_completion
}
# Fallback: if the idle trigger never fires, init on the next prompt regardless.
_fast_defer_fallback() {
	(( ${_fast_done:-0} )) || _fast_init_completion
	add-zsh-hook -d precmd _fast_defer_fallback
}
_fast_defer_setup() {
	add-zsh-hook -d precmd _fast_defer_setup            # run once
	exec {_fast_fd}< <(:)                               # fd at EOF: fires on first ZLE idle
	zle -F $_fast_fd _fast_run_deferred
	add-zsh-hook precmd _fast_defer_fallback
}
autoload -Uz add-zsh-hook
add-zsh-hook precmd _fast_defer_setup

