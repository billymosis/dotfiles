function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

# Master Sync Function
# Usage: sync_zk up   (Local -> Cloud)
# Usage: sync_zk down (Cloud -> Local)
sync_zk() {
	local direction=$1
	local excludes=(
		--exclude=".git/"
		--exclude=".trash/"
		--exclude="book/"
		--exclude="*.pdf"
		--exclude="*.epub"
	)

	# Use trailing slashes on source variables to sync contents
	if [[ "$direction" == "up" ]]; then
		# Syncing contents of local to cloud
		rsync -rtu "${excludes[@]}" "${ZK_NOTEBOOK_DIR}/" "$ZK_CLOUD_DIR" -v
	elif [[ "$direction" == "down" ]]; then
		# Syncing contents of cloud to local
		rsync -rtu --delete "${excludes[@]}" "${ZK_CLOUD_DIR}/" "$ZK_NOTEBOOK_DIR" -v
	else
		echo "Usage: sync_zk [up|down]"
	fi
}
# . "$HOME/.atuin/bin/env"

function my_init() {
	# Cache atuin's generated init (~100ms) instead of regenerating every shell.
	# Regenerated automatically when the atuin binary is newer than the cache.
	local _atuin_bin="$(command -v atuin)" _atuin_cache="${HOME}/.cache/atuin-init.zsh"
	if [[ -n "$_atuin_bin" && ( ! -s "$_atuin_cache" || "$_atuin_bin" -nt "$_atuin_cache" ) ]]; then
		atuin init zsh > "$_atuin_cache"
	fi
	[[ -s "$_atuin_cache" ]] && source "$_atuin_cache"
}

