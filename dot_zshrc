function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

# Master Sync Function
# Usage: sync_zk up   (Local -> Cloud)
# Usage: sync_zk down (Cloud -> Local)
sync_zk() {
	local direction=$1
	local excludes=(
		--exclude=".git/"
		--exclude=".trash/"
		--exclude="book/"
		--exclude="*.pdf"
		--exclude="*.epub"
	)

	# Use trailing slashes on source variables to sync contents
	if [[ "$direction" == "up" ]]; then
		# Syncing contents of local to cloud
		rsync -rtu "${excludes[@]}" "${ZK_NOTEBOOK_DIR}/" "$ZK_CLOUD_DIR" -v
	elif [[ "$direction" == "down" ]]; then
		# Syncing contents of cloud to local
		rsync -rtu --delete "${excludes[@]}" "${ZK_CLOUD_DIR}/" "$ZK_NOTEBOOK_DIR" -v
	else
		echo "Usage: sync_zk [up|down]"
	fi
}
